<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Codex Bridge สำหรับ PIP Agent Dashboard</title>
<style>
  :root {
    --paper:#fffaf2;
    --ink:#2f251f;
    --muted:#69594c;
    --line:#dfcbb3;
    --gold:#c99036;
    --green:#577848;
    --red:#9d4636;
  }
  * { box-sizing:border-box; }
  body {
    margin:0;
    min-height:100vh;
    padding:30px;
    color:var(--ink);
    background:linear-gradient(180deg, #fbf4e9, #efe1cd);
    font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    line-height:1.65;
  }
  main {
    width:min(920px, 100%);
    margin:0 auto;
  }
