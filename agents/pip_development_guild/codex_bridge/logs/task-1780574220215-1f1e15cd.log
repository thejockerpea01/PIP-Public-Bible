function setSceneScale() {
  const rect = scene.getBoundingClientRect();
  sceneScale.style.transform = `scale(${rect.width / 1931})`;
}

function setDialoguePanel(panelName) {
  workflowPanel.hidden = panelName !== "workflow";
  copyState.textContent = "";
}

function debugLog(...args) {
  if (!DEBUG_AGENT_DASHBOARD || typeof console === "undefined") return;
  console.log(...args);
}

function setDialogueExpanded(expanded) {
  dialogueExpanded = expanded;
  dialogue.classList.toggle("expanded", dialogueExpanded);
  expandDialogueButton.dataset.expanded = dialogueExpanded ? "true" : "false";
  expandDialogueButton.title = dialogueExpanded ? "ย่อกลับ" : "ขยาย";
  expandDialogueButton.setAttribute("aria-label", dialogueExpanded ? "ย่อกลับ" : "ขยาย");
}

function setCommandPanelCollapsed(collapsed) {
  isCommandPanelCollapsed = collapsed;
  commandPanel.classList.toggle("collapsed", isCommandPanelCollapsed);
  commandPanel.classList.toggle("is-collapsed", isCommandPanelCollapsed);
  reopenCommandPanel.hidden = !isCommandPanelCollapsed;
}

function renderList(listNode, items) {
  listNode.innerHTML = "";
  items.forEach((item) => {
    const li = document.createElement("li");
    li.textContent = item;
    listNode.appendChild(li);
  });
}

function renderTaskPresets(agent, workflow) {
  taskPresetList.innerHTML = "";
  selectedTaskPreset = workflow.presets[0] || "";
  selectedTaskPresetEnglish = (workflow.presetsEnglish && workflow.presetsEnglish[0]) || selectedTaskPreset;
  selectedTaskPresetHelp = (workflow.presetHelp && workflow.presetHelp[0]) || workflow.presetHelpDefault || "";
  presetHint.textContent = selectedTaskPresetHelp;
  workflow.presets.forEach((preset, index) => {
    const button = document.createElement("button");
    button.type = "button";
    button.className = "preset-button";
    button.textContent = preset;
    button.dataset.preset = preset;
    button.dataset.presetEnglish = (workflow.presetsEnglish && workflow.presetsEnglish[index]) || preset;
    button.dataset.presetHelp = (workflow.presetHelp && workflow.presetHelp[index]) || workflow.presetHelpDefault || "";
    if (preset === selectedTaskPreset) button.classList.add("active");
    button.addEventListener("click", (event) => {
      event.stopPropagation();
      selectedTaskPreset = preset;
      selectedTaskPresetEnglish = button.dataset.presetEnglish;
      selectedTaskPresetHelp = button.dataset.presetHelp || workflow.presetHelpDefault || "";
      taskPresetList.querySelectorAll(".preset-button").forEach((item) => {
        item.classList.toggle("active", item.dataset.preset === preset);
      });
      presetHint.textContent = selectedTaskPresetHelp;
      taskWarning.textContent = "";
      taskWarning.classList.remove("warning");
    });
    taskPresetList.appendChild(button);
  });
}

function renderWorkflow(agent) {
  const workflow = workflowTemplates[agent.id];
  if (!workflow) {
    debugLog("[AgentClick] missing workflow template", agent.id, agent.name);
    return;
  }
  workflowAgentContext.textContent = `${agent.thaiName} · ${agent.thaiRole}`;
  workflowInstruction.textContent = "เลือกงานที่ต้องการให้เอเจนต์ช่วย แล้วเขียนรายละเอียด จากนั้นกดส่งให้ Codex";
  renderTaskPresets(agent, workflow);
  if (workflowChecklist) {
    renderList(workflowChecklist, workflow.checklist);
  }
  taskDetailInput.value = "";
  taskWarning.textContent = "";
  taskWarning.classList.remove("warning");
  workflowPrompt.value = "";
  workflowPrompt.placeholder = "เลือกประเภทงานและเขียนรายละเอียดก่อน ระบบจะสร้างคำสั่งให้ที่นี่";
  copyState.textContent = "";
  copyPromptButton.disabled = true;
  fullAutomateButton.hidden = agent.id !== "01";
  bridgeHint.textContent = bridgeAvailable ? "ระบบจะส่งคำสั่งนี้ไปที่ Codex ผ่านเครื่องของคุณ" : "เปิด Codex Bridge ก่อน หรือใช้ Copy Prompt แทน";
  latestTaskSummary.textContent = "ยังไม่มีงานล่าสุด";
  updateBridgeControls();
}

function formatPromptList(items) {
  return items.map((item) => `- ${item}`).join("\n");
}

function buildGeneratedPrompt(agent, workflow, taskPreset, taskPresetEnglish, taskDetails) {
  const readFirst = workflow.readFirst || ["README.html", "AGENTS.html"];
  const baseRules = [
    "Do not use archive/ files.",
    "Preserve approved canon unless explicitly requested.",
    "Do not modify unrelated files.",
    "Do not turn this into a visual redesign task.",
    "Follow the current Product Bible and approved role mapping.",
    "Keep user-facing UI Thai if UI copy is involved.",
    "Do not call external APIs unless explicitly requested.",
    "Do not modify approved images, sprites, backgrounds, character coordinates, hitboxes, hover/ring logic, or scene scaling unless explicitly requested."
  ];

  return `Start from README.html and AGENTS.html.
Act as ${workflow.codexRole}.

Agent role instruction:
${workflow.prompt}

Task:
${taskDetails}

Task type:
${taskPresetEnglish} (${taskPreset})

Read first:
${formatPromptList(readFirst)}

Scope:
- Work only on the files and behavior directly related to the requested task.
- Use existing project structure, canon files, and approved UI/system rules.
- Treat Product Bible, Guild canon, and approved role mapping as source-of-truth constraints.

Rules:
${formatPromptList(baseRules)}

Expected output:
${workflow.expectedOutput}

Report requirements:
- Files read.
- Files changed, if any.
- What was implemented or audited.
- Verification steps and results.
- Any risks, mismatches, or follow-up items.
`;
}

function createCommandPayload(agent, workflow, taskPreset, taskPresetEnglish, taskDetails) {
  return {
    mode:"local-codex-bridge",
    bridge:"http://127.0.0.1:8787",
    targetAgent:agent.id,
    agentName:`${agent.number} ${agent.thaiName}`,
    agentRole:workflow.codexRole,
    taskType:taskPreset,
    taskTypeEnglish:taskPresetEnglish,
    taskDetails,
    filesToRead:workflow.readFirst || ["README.html", "AGENTS.html"],
    guardrails:[
      "Do not use archive/ files.",
      "Preserve approved canon unless explicitly requested.",
      "Do not modify unrelated files.",
      "Do not modify approved images, sprites, backgrounds, character coordinates, hitboxes, hover/ring logic, or scene scaling unless explicitly requested."
    ],
    expectedOutput:workflow.expectedOutput
  };
}

function createTask(agent, taskPreset, taskPresetEnglish, taskDetails, extra = {}) {
  const workflow = workflowTemplates[agent.id];
  const generatedPrompt = buildGeneratedPrompt(agent, workflow, taskPreset, taskPresetEnglish, taskDetails);
  return {
    id:`task-${String(taskSequence++).padStart(3, "0")}`,
    agentId:agent.id,
    agentName:`${agent.number} ${agent.thaiName}`,
    taskType:taskPreset,
    taskTitle:taskPreset,
    taskDetails,
    status:"queued",
    createdAt:new Date().toISOString(),
    startedAt:null,
    completedAt:null,
    generatedPrompt,
    resultSummary:"",
    commandPayload:createCommandPayload(agent, workflow, taskPreset, taskPresetEnglish, taskDetails),
    parentTaskId:extra.parentTaskId || null,
    bridgeTaskId:extra.bridgeTaskId || null,
    dispatchRole:extra.dispatchRole || null
  };
}

function normalizeBridgeTask(task) {
  return {
    id:task.id,
    agentId:task.agentId,
    agentName:task.agentName,
    taskType:task.taskType,
    taskTitle:task.taskType,
    taskDetails:task.taskDetails,
    status:task.status,
    createdAt:task.createdAt,
    startedAt:task.startedAt,
    completedAt:task.completedAt,
    generatedPrompt:"",
    resultSummary:task.result || "",
    commandPayload:null,
    parentTaskId:task.parentTaskId || null,
    bridgeTaskId:task.bridgeTaskId || task.id,
    dispatchRole:task.dispatchRole || null
  };
}

function updateBridgeControls() {
  if (!bridgeStatusText) return;
  const dispatchRunning = Boolean(activeDispatch && activeDispatch.status === "running");
  sendAgentTaskButton.disabled = !bridgeAvailable && !(selectedAgent && selectedAgent.id === "01");
  fullAutomateButton.disabled = dispatchRunning;
  bridgeStatusText.textContent = bridgeAvailable ? "Codex Bridge พร้อมใช้งาน" : "ยังไม่ได้เปิด Codex Bridge";
  bridgeStatusText.classList.toggle("offline", !bridgeAvailable);
  bridgeStatusText.classList.toggle("ready", bridgeAvailable);
  if (bridgeHint) {
    bridgeHint.textContent = bridgeAvailable
      ? "ระบบจะส่งคำสั่งนี้ไปที่ Codex ผ่านเครื่องของคุณ"
      : "เปิด Codex Bridge ก่อน หรือใช้ Copy Prompt แทน";
  }
}

async function checkBridgeHealth() {
  try {
    const response = await fetch(`${BRIDGE_URL}/health`, { cache:"no-store" });
    const data = await response.json();
    bridgeAvailable = Boolean(response.ok && data.ok);
  } catch (error) {
    bridgeAvailable = false;
  }
  updateBridgeControls();
}

function startBridgePolling() {
  if (bridgePollTimer) return;
  bridgePollTimer = setInterval(loadBridgeTasks, 3000);
}

function stopBridgePollingIfIdle() {
  if (!bridgePollTimer) return;
  if (activeDispatch && activeDispatch.status === "running") return;
  if (tasks.some((task) => task.status === "queued" || task.status === "running")) return;
  clearInterval(bridgePollTimer);
  bridgePollTimer = null;
}

function mergeBridgeTasks(bridgeTasks) {
  bridgeTasks.map(normalizeBridgeTask).forEach((bridgeTask) => {
    const existing = tasks.find((task) => task.id === bridgeTask.id || task.bridgeTaskId === bridgeTask.id);
    if (existing) {
      const generatedPrompt = existing.generatedPrompt;
      const commandPayload = existing.commandPayload;
      const parentTaskId = existing.parentTaskId || bridgeTask.parentTaskId;
      const dispatchRole = existing.dispatchRole || bridgeTask.dispatchRole;
      Object.assign(existing, bridgeTask, {
        generatedPrompt,
        commandPayload,
        parentTaskId,
        dispatchRole,
        bridgeTaskId:bridgeTask.id
      });
    } else {
      tasks.push(bridgeTask);
    }
  });
}

async function loadBridgeTasks() {
  try {
    const response = await fetch(`${BRIDGE_URL}/tasks`, { cache:"no-store" });
    if (!response.ok) throw new Error("ไม่สามารถอ่านคิวจาก Codex Bridge");
    const data = await response.json();
    mergeBridgeTasks(data);
    await advanceActiveDispatch();
    renderCommandPanel();
    stopBridgePollingIfIdle();
  } catch (error) {
    bridgeAvailable = false;
    updateBridgeControls();
  }
}

async function sendTaskToBridge(task) {
  const response = await fetch(`${BRIDGE_URL}/tasks`, {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({
      agentId:task.agentId,
      agentName:task.agentName,
      taskType:task.taskType,
      taskDetails:task.taskDetails,
      prompt:task.generatedPrompt,
      parentTaskId:task.parentTaskId || null
    })
  });
  const data = await response.json();
  if (!response.ok) throw new Error(data.error || "ส่งงานเข้า Codex Bridge ไม่สำเร็จ");
  return normalizeBridgeTask(data);
}

function prepareSelectedTaskPrompt() {
  if (!selectedAgent) return null;
  const taskDetails = taskDetailInput.value.trim();
  copyState.textContent = "";
  if (!taskDetails) {
    taskWarning.textContent = "กรุณากรอกรายละเอียดงานก่อน";
    taskWarning.classList.add("warning");
    workflowPrompt.value = "";
    workflowPrompt.placeholder = "เลือกประเภทงานและเขียนรายละเอียดก่อน ระบบจะสร้างคำสั่งให้ที่นี่";
    copyPromptButton.disabled = true;
    return null;
  }

  const task = createTask(selectedAgent, selectedTaskPreset, selectedTaskPresetEnglish, taskDetails);
  taskWarning.textContent = "เตรียมคำสั่งสำหรับ Codex แล้ว";
  taskWarning.classList.remove("warning");
  workflowPrompt.value = task.generatedPrompt;
  copyPromptButton.disabled = false;
  return task;
}

function queueTask(task, shouldStart) {
  tasks.push(task);
  taskWarning.textContent = shouldStart ? "งานเข้าคิวแล้ว" : "เตรียมคำสั่งสำหรับ Codex แล้ว";
  taskWarning.classList.remove("warning");
  latestTaskSummary.textContent = `${task.agentName} · ${task.taskTitle} · ${statusThai[task.status]}`;
  workflowPrompt.value = task.generatedPrompt;
  copyPromptButton.disabled = false;
  renderCommandPanel();
  if (shouldStart) startLocalQueue();
}

async function submitSelectedTask(shouldSendToBridge) {
  if (shouldSendToBridge && selectedAgent && selectedAgent.id === "01") {
    await createFullAutomatePlan();
    return;
  }
  const task = prepareSelectedTaskPrompt();
  if (!task) return;
  if (!shouldSendToBridge) {
    queueTask(task, false);
    return;
  }
  if (!bridgeAvailable) {
    taskWarning.textContent = "ยังไม่ได้เปิด Codex Bridge";
    taskWarning.classList.add("warning");
    return;
  }
  try {
    sendAgentTaskButton.disabled = true;
    const bridgeTask = await sendTaskToBridge(task);
    tasks = tasks.filter((item) => item.id !== bridgeTask.id);
    tasks.push(bridgeTask);
    taskWarning.textContent = bridgeStatusMessage[bridgeTask.status] || "งานเข้าคิวแล้ว";
    taskWarning.classList.remove("warning");
    renderCommandPanel();
    latestTaskSummary.textContent = `${bridgeTask.agentName} · ${bridgeTask.taskTitle} · ${statusThai[bridgeTask.status]}`;
    startBridgePolling();
  } catch (error) {
    taskWarning.textContent = "งานติดปัญหา";
    taskWarning.classList.add("warning");
  } finally {
    updateBridgeControls();
  }
}

async function createFullAutomatePlan() {
  if (!selectedAgent || selectedAgent.id !== "01") return;
  if (activeDispatch && activeDispatch.status === "running") {
    taskWarning.textContent = "กำลังกระจายงานอัตโนมัติอยู่ รอคิวนี้จบก่อน";
    taskWarning.classList.add("warning");
    return;
  }
  const goal = taskDetailInput.value.trim();
  copyState.textContent = "";
  if (!goal) {
    taskWarning.textContent = "กรุณากรอกรายละเอียดงานก่อน";
    taskWarning.classList.add("warning");
    return;
  }

  if (!bridgeAvailable) {
    taskWarning.textContent = "ยังไม่ได้เปิด Codex Bridge จึงยังไม่สามารถกระจายงานอัตโนมัติได้";
    taskWarning.classList.add("warning");
    return;
  }

  const parentTask = createTask(
    selectedAgent,
    "วางแผนอัตโนมัติ",
    "Sequential multi-agent dispatch",
    `Break this goal into a safe sequential dispatch plan for agents 02-11: ${goal}`,
    { dispatchRole:"parent" }
  );
  parentTask.status = "running";
  parentTask.startedAt = new Date().toISOString();
  parentTask.resultSummary = "กำลังกระจายงานให้เอเจนต์ทีละตัวผ่าน Codex Bridge";

  const plannedTasks = createDispatchChildTasks(goal, parentTask.id);
  workflowPrompt.value = plannedTasks.map((task, index) => `${index + 1}. ${task.agentName} - ${task.taskTitle}\n${task.generatedPrompt}`).join("\n\n---\n\n");
  copyPromptButton.disabled = false;
  activeDispatch = {
    id:parentTask.id,
    parentTaskId:parentTask.id,
    status:"running",
    childTaskIds:plannedTasks.map((task) => task.id),
    activeChildId:null,
    finalNoteShown:false
  };
  tasks.push(parentTask, ...plannedTasks);
  taskWarning.textContent = "กำลังรันทีละงานผ่าน Codex Bridge ไม่รันพร้อมกันเพื่อความปลอดภัย";
  taskWarning.classList.remove("warning");
  latestTaskSummary.textContent = `วางแผนอัตโนมัติ · ${plannedTasks.length} งานรอคิว`;
  renderCommandPanel();
  try {
    fullAutomateButton.disabled = true;
    await advanceActiveDispatch();
    startBridgePolling();
  } catch (error) {
    taskWarning.textContent = "งานติดปัญหา";
    taskWarning.classList.add("warning");
  } finally {
    updateBridgeControls();
  }
}

