  .dialogue.open {
    opacity:1;
    pointer-events:auto;
    transform:translate(-50%, -4px);
  }
  .dialogue.expanded.open {
    transform:translateX(0);
  }
  .dialogue::before {
    content:"";
    position:absolute;
    inset:7px;
    border:1px solid rgba(255, 232, 177, .20);
    border-radius:12px;
    pointer-events:none;
  }
