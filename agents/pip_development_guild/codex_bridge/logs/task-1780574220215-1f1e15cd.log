    font-weight:900;
  }
  .dialogue-title {
    margin:0;
    color:#fff8e8;
    font-family:"Iowan Old Style", "Palatino Linotype", Georgia, serif;
    font-size:26px;
    line-height:1.05;
    letter-spacing:0;
  }
  .dialogue-meta {
    display:grid;
    gap:2px;
    margin-top:8px;
  }
  .dialogue-meta-line {
    margin:0;
    color:#f0dcc4;
    font-size:13px;
    font-weight:800;
    line-height:1.35;
  }

