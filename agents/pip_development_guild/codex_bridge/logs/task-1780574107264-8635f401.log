function formatTaskLine(task) {
  const agent = getTaskAgent(task);
  return `<p class="command-item"><strong>${task.agentName}</strong><br>${task.taskTitle}<br>${agent ? agent.thaiRole : ""}</p>`;
}

function renderTaskList(container, items, emptyText, limit) {
  const visibleItems = typeof limit === "number" ? items.slice(0, limit) : items;
  container.innerHTML = visibleItems.length
    ? visibleItems.map(formatTaskLine).join("")
    : `<p class="command-empty">${emptyText}</p>`;
}

function getAgentStatus(agent) {
  const active = tasks.find((task) => task.agentId === agent.id && task.status === "running");
  if (active) return { status:"running", task:active };
  const queued = tasks.find((task) => task.agentId === agent.id && task.status === "queued");
  if (queued) return { status:"queued", task:queued };
  const latest = tasks.filter((task) => task.agentId === agent.id && (task.status === "completed" || task.status === "failed")).at(-1);
  if (latest) return { status:latest.status, task:latest };
  return { status:"idle", task:null };
}

function renderAgentStatuses() {
  agentStatusTable.innerHTML = agents.map((agent) => {
    const state = getAgentStatus(agent);
    const taskText = state.task ? state.task.taskTitle : "ไม่มีงานค้าง";
    return `
      <div class="agent-status-row">
        <div class="agent-status-number">${agent.number}</div>
        <div>
          <p class="agent-status-name">${agent.thaiName}</p>
          <p class="agent-status-role">${agent.thaiRole}</p>
          <p class="agent-status-task">${taskText}</p>
        </div>
        <div class="status-pill status-${state.status}">${statusThai[state.status]}</div>
      </div>
    `;
  }).join("");
}

function renderCommandPanel() {
  const activeTasks = tasks.filter((task) => task.status === "running");
  const queuedTasks = tasks.filter((task) => task.status === "queued");
  const completedTasks = tasks.filter((task) => task.status === "completed" || task.status === "failed").slice(-3).reverse();
  if (activeDispatch && activeDispatch.status === "running") {
    dispatchNotice.textContent = "กำลังรันทีละงานผ่าน Codex Bridge ไม่รันพร้อมกันเพื่อความปลอดภัย";
  } else if (activeDispatch && activeDispatch.status === "completed") {
    dispatchNotice.textContent = "งานกระจายครบทุกเอเจนต์แล้ว ตรวจ log ของแต่ละงานได้ใน Codex Bridge";
  } else {
    dispatchNotice.textContent = "ยังไม่มีงานกระจายอัตโนมัติ";
  }
  renderTaskList(activeTaskView, activeTasks, "ยังไม่มีงานที่กำลังทำ", 1);
  renderTaskList(queuedTaskView, queuedTasks, "ยังไม่มีงานรอคิว", 5);
  renderTaskList(completedTaskView, completedTasks, "ยังไม่มีงานที่เสร็จแล้ว", 3);
  renderAgentStatuses();
  const latestTask = tasks.at(-1);
  latestTaskSummary.textContent = latestTask
    ? `${latestTask.agentName} · ${latestTask.taskTitle} · ${statusThai[latestTask.status]}`
    : "ยังไม่มีงานล่าสุด";
}

function startNextTask() {
  if (bridgeAvailable) {
    loadBridgeTasks();
    startBridgePolling();
    return;
  }
  startLocalQueue();
}

function stopQueue() {
  queueRunning = false;
  if (activeTaskTimer) {
    clearTimeout(activeTaskTimer);
    activeTaskTimer = null;
  }
  if (bridgePollTimer) {
    clearInterval(bridgePollTimer);
    bridgePollTimer = null;
  }
  renderCommandPanel();
}

function clearCompletedTasks() {
  tasks = tasks.filter((task) => task.status !== "completed" && task.status !== "failed");
  renderCommandPanel();
}

function startLocalQueue() {
  if (bridgeAvailable) return;
  if (queueRunning) return;
  queueRunning = true;
  processLocalQueue();
}

function processLocalQueue() {
  if (!queueRunning) return;
  if (tasks.some((task) => task.status === "running")) return;
  const nextTask = tasks.find((task) => task.status === "queued");
  if (!nextTask) {
    queueRunning = false;
    renderCommandPanel();
    return;
  }

  nextTask.status = "running";
  nextTask.startedAt = new Date().toISOString();
  nextTask.resultSummary = "จำลองการทำงาน: เตรียมคำสั่งสำหรับ Codex และรอเชื่อมต่อ Codex Bridge";
  renderCommandPanel();
  activeTaskTimer = setTimeout(() => {
    nextTask.status = "completed";
    nextTask.completedAt = new Date().toISOString();
    nextTask.resultSummary = "เสร็จแล้วในโหมดจำลอง ยังไม่ได้รัน Codex จริง";
    activeTaskTimer = null;
    renderCommandPanel();
    processLocalQueue();
  }, 1800);
}

async function copyWorkflowPrompt() {
  const promptText = workflowPrompt.value;
  if (!promptText.trim()) {
    copyState.textContent = "ยังไม่มี Prompt ให้คัดลอก";
    return;
  }
  try {
    await navigator.clipboard.writeText(promptText);
  } catch (error) {
    workflowPrompt.focus();
    workflowPrompt.select();
    document.execCommand("copy");
  }
  copyState.textContent = "คัดลอก Prompt แล้ว";
}

