      node.style.setProperty("--w", `${agent.width}px`);
      node.style.setProperty("--h", `${agent.height}px`);
      node.style.setProperty("--label-x", `${agent.labelOffsetX}px`);
      node.style.setProperty("--label-y", `${agent.labelOffsetY}px`);
      node.style.setProperty("--hit-w", `${agent.hitboxWidth}px`);
      node.style.setProperty("--hit-h", `${agent.hitboxHeight}px`);
      node.style.setProperty("--ring-w", `${agent.highlightWidth}px`);
      node.style.setProperty("--ring-h", `${agent.highlightHeight}px`);
      node.style.setProperty("--duration", agent.duration);
      node.style.setProperty("--scale", agent.scale);

      const z = 20 + index;
      node.innerHTML = `
        <div class="agent" style="z-index:${z};">
          <div class="sprite-motion ${agent.motion}">
            <img class="agent-sprite" src="${agent.spritePath}" alt="${agent.number} ${agent.name}">
          </div>
        </div>
        <div class="highlight"></div>
        <div class="agent-label">${agent.number} ${agent.name}</div>
        <button class="hitbox" type="button" aria-label="${agent.number} ${agent.name}"></button>
      `;
      const hitbox = node.querySelector(".hitbox");
      hitbox.addEventListener("mouseenter", () => node.classList.add("hovered"));
      hitbox.addEventListener("mouseleave", () => node.classList.remove("hovered"));
      hitbox.addEventListener("focus", () => node.classList.add("hovered"));
      hitbox.addEventListener("blur", () => node.classList.remove("hovered"));
      hitbox.addEventListener("click", (event) => {
        event.stopPropagation();
        debugLog("[AgentClick] hotspot clicked", agent.id, agent.name);
        openDialogue(agent, node);
      });
      agentLayer.appendChild(node);
    });
}

function openDialogue(agent, node) {
  debugLog("[AgentClick] openDialogue called", agent.id, agent.name);
  if (selectedNode) selectedNode.classList.remove("selected");
  selectedNode = node;
  selectedAgent = agent;
  selectedNode.classList.add("selected");
  document.getElementById("agentTitle").textContent = `${agent.number} ${agent.thaiName}`;
  document.getElementById("agentRole").textContent = `บทบาท: ${agent.thaiRole}`;
  document.getElementById("agentZone").textContent = `พื้นที่: ${agent.zone}`;
  renderWorkflow(agent);
  setDialoguePanel("workflow");
  setDialogueExpanded(false);
  dialogue.classList.add("open");
  dialogue.setAttribute("aria-hidden", "false");
  tip.classList.add("hidden");
  debugLog("[AgentClick] panel state", {
    open: dialogue.classList.contains("open"),
    expanded: dialogue.classList.contains("expanded"),
    selectedAgent: selectedAgent && selectedAgent.id,
    commandPanelCollapsed: isCommandPanelCollapsed
  });
}

function closeDialogue() {
  dialogue.classList.remove("open");
  dialogue.setAttribute("aria-hidden", "true");
  if (selectedNode) {
    selectedNode.classList.remove("selected");
    selectedNode = null;
  }
  selectedAgent = null;
  setDialoguePanel("workflow");
  setDialogueExpanded(false);
  tip.classList.remove("hidden");
}

