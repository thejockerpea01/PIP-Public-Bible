<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Visual Agent Team Skill</title>
<style>
:root{--bg:#f7efe4;--paper:#fffaf2;--ink:#2f251f;--muted:#745f50;--line:#dfcbb3;--gold:#c99036;--brown:#6f4728;--green:#5f7f4c;--red:#a94a3a;--shadow:rgba(73,48,26,.14)}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color:var(--ink);background:radial-gradient(circle at top left,rgba(201,144,54,.2),transparent 28%),radial-gradient(circle at top right,rgba(95,127,76,.18),transparent 32%),linear-gradient(180deg,#fbf4e9 0%,#efe1cd 100%);line-height:1.65}
.layout{display:grid;grid-template-columns:290px minmax(0,1fr);min-height:100vh}
aside{position:sticky;top:0;height:100vh;overflow-y:auto;padding:24px 18px;background:rgba(72,45,24,.92);color:#fff5e6;border-right:1px solid rgba(255,255,255,.12)}
aside h2{margin:0 0 6px;font-size:18px}aside p{margin:0 0 18px;color:#e8d4ba;font-size:13px}nav a{display:block;padding:9px 10px;margin:4px 0;color:#fff5e6;text-decoration:none;border-radius:10px;font-size:13px}nav a:hover{background:rgba(255,255,255,.12)}
main{padding:32px;max-width:1240px;width:100%}.hero{position:relative;overflow:hidden;padding:34px;border:1px solid var(--line);border-radius:28px;background:linear-gradient(135deg,rgba(255,250,242,.96),rgba(255,244,228,.92));box-shadow:0 18px 38px var(--shadow);margin-bottom:22px}
.eyebrow{display:inline-flex;align-items:center;gap:8px;padding:7px 11px;border-radius:999px;background:#fff1d6;border:1px solid #ead19a;color:#754d16;font-size:13px;font-weight:800;margin-bottom:14px}
h1{margin:0;font-size:clamp(32px,5vw,56px);letter-spacing:-.06em;line-height:1}.hero .lead{margin:16px 0 0;max-width:880px;font-size:18px;color:var(--muted)}
section{margin:22px 0;padding:24px;border:1px solid var(--line);border-radius:24px;background:rgba(255,250,242,.92);box-shadow:0 12px 28px rgba(73,48,26,.08)}
h2{margin:0 0 14px;font-size:26px;letter-spacing:-.03em}h3{margin:18px 0 8px;font-size:19px}p,li{color:var(--muted);margin:8px 0}ul,ol{padding-left:22px;margin:10px 0}
.grid{display:grid;gap:14px}.grid.two{grid-template-columns:repeat(2,minmax(0,1fr))}.grid.three{grid-template-columns:repeat(3,minmax(0,1fr))}
.card{padding:18px;border-radius:18px;border:1px solid var(--line);background:linear-gradient(180deg,#fffdf8,#fff6ea)}.card h3{margin-top:0}
.badge-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}.badge{display:inline-flex;padding:8px 11px;border-radius:999px;font-size:13px;font-weight:800;border:1px solid #d9c39f;background:#fff7e8;color:#6e4728}
code{padding:2px 7px;border-radius:7px;background:#f3e5d4;border:1px solid #e1cbb3;color:#5f3c24;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;font-size:.92em}
pre{overflow-x:auto;padding:16px;border-radius:16px;background:#2b211b;color:#fff4e1;border:1px solid rgba(255,255,255,.08);font-size:13px;line-height:1.55}
table{width:100%;border-collapse:collapse;overflow:hidden;border-radius:16px;border:1px solid var(--line);background:#fffdf8}th,td{padding:12px;border-bottom:1px solid #eadac7;vertical-align:top;text-align:left;font-size:14px}th{background:#f1e1cc;color:#503829;font-size:12px;text-transform:uppercase;letter-spacing:.04em}tr:last-child td{border-bottom:none}
.callout{padding:16px;border-radius:16px;background:#fff1df;border-left:5px solid var(--gold);color:var(--muted);margin:14px 0}.danger{border-left-color:var(--red);background:#fff0ea}.ok{border-left-color:var(--green);background:#eff8ea}
.phase{display:flex;gap:14px;align-items:flex-start}.phase-num{flex:0 0 auto;width:42px;height:42px;display:grid;place-items:center;border-radius:14px;background:var(--brown);color:white;font-weight:900}.phase-body h3{margin:0 0 4px}
footer{padding:26px 0 8px;color:var(--muted);font-size:13px}
@media(max-width:1000px){.layout{display:block}aside{position:relative;height:auto}main{padding:18px}.grid.two,.grid.three{grid-template-columns:1fr}}
</style>
