async function createFullAutomatePlan() {
  if (!selectedAgent || selectedAgent.id !== "01") return;
  if (activeDispatch && activeDispatch.status === "running") {
    taskWarning.textContent = "กำลังกระจายงานอัตโนมัติอยู่ รอคิวนี้จบก่อน";
    taskWarning.classList.add("warning");
    return;
  }
  const goal = taskDetailInput.value.trim();
  copyState.textContent = "";
  if (!goal) {
    taskWarning.textContent = "กรุณากรอกรายละเอียดงานก่อน";
    taskWarning.classList.add("warning");
    return;
  }

  if (!bridgeAvailable) {
    taskWarning.textContent = "ยังไม่ได้เปิด Codex Bridge จึงยังไม่สามารถกระจายงานอัตโนมัติได้";
    taskWarning.classList.add("warning");
    return;
  }

  const parentTask = createTask(
    selectedAgent,
    "วางแผนอัตโนมัติ",
    "Sequential multi-agent dispatch",
    `Break this goal into a safe sequential dispatch plan for agents 02-11: ${goal}`,
    { dispatchRole:"parent" }
  );
  parentTask.status = "running";
  parentTask.startedAt = new Date().toISOString();
  parentTask.resultSummary = "กำลังกระจายงานให้เอเจนต์ทีละตัวผ่าน Codex Bridge";

  const plannedTasks = createDispatchChildTasks(goal, parentTask.id);
  workflowPrompt.value = plannedTasks.map((task, index) => `${index + 1}. ${task.agentName} - ${task.taskTitle}\n${task.generatedPrompt}`).join("\n\n---\n\n");
  copyPromptButton.disabled = false;
  activeDispatch = {
    id:parentTask.id,
    parentTaskId:parentTask.id,
    status:"running",
    childTaskIds:plannedTasks.map((task) => task.id),
    activeChildId:null,
    finalNoteShown:false
  };
  tasks.push(parentTask, ...plannedTasks);
  taskWarning.textContent = "กำลังรันทีละงานผ่าน Codex Bridge ไม่รันพร้อมกันเพื่อความปลอดภัย";
  taskWarning.classList.remove("warning");
  latestTaskSummary.textContent = `วางแผนอัตโนมัติ · ${plannedTasks.length} งานรอคิว`;
  renderCommandPanel();
  try {
    fullAutomateButton.disabled = true;
    await advanceActiveDispatch();
    startBridgePolling();
  } catch (error) {
    taskWarning.textContent = "งานติดปัญหา";
    taskWarning.classList.add("warning");
  } finally {
    updateBridgeControls();
  }
}

function createDispatchChildTasks(goal, parentTaskId) {
  const plan = [
    { agentId:"02", preset:"ตรวจ Source of Truth", presetEnglish:"Audit source of truth", detail:`Inspect source-of-truth, canon, rule conflicts, and unsafe assumptions for this goal. Inspection only. Goal: ${goal}` },
    { agentId:"03", preset:"ทำ Handoff", presetEnglish:"Create handoff", detail:`Prepare a handoff summary structure for this dispatched workflow, including decisions, open issues, and next-step reporting. Inspection only. Goal: ${goal}` },
    { agentId:"04", preset:"ตรวจ Design System", presetEnglish:"Audit design system", detail:`Audit UX clarity, design-system consistency, visual canon, spacing, typography, and interaction wording for this goal. Inspection only. Goal: ${goal}` },
    { agentId:"05", preset:"ตรวจ Build Error", presetEnglish:"Inspect implementation maintainability", detail:`Inspect HTML/CSS/JS maintainability, structure, brittle code paths, and implementation risks related to this goal. Inspection only. Goal: ${goal}` },
    { agentId:"06", preset:"ตรวจ Security", presetEnglish:"Security audit", detail:`Audit Codex Bridge safety, client trust boundaries, unsafe browser execution risk, and system integrity for this goal. Inspection only. Goal: ${goal}` },
    { agentId:"07", preset:"ตรวจ Mini Game Flow", presetEnglish:"Review product mode logic", detail:`Check Product Modes and Mini Game role logic for conflicts or missing guardrails related to this goal. Inspection only. Goal: ${goal}` },
    { agentId:"08", preset:"ทำ QA Checklist", presetEnglish:"Create QA checklist", detail:`Create a focused QA and regression checklist for this dispatched workflow. Inspection only. Goal: ${goal}` },
    { agentId:"09", preset:"ตรวจ Practice Mode", presetEnglish:"Review Practice and Mock Exam readiness", detail:`Check Practice Mode, Mock Exam, accuracy review, and 100-question session readiness where relevant to this goal. Inspection only. Goal: ${goal}` },
    { agentId:"10", preset:"Review Architecture", presetEnglish:"Review architecture and technical debt", detail:`Review architecture, technical debt, maintainability, coupling, and long-term structure risks for this goal. Inspection only. Goal: ${goal}` },
    { agentId:"11", preset:"ตรวจ Reward Logic", presetEnglish:"Review reward and monetization guardrails", detail:`Check Reward, VIP, monetization, x2 ticket, and rewarded ad guardrails for conflicts or duplicate-reward risk related to this goal. Inspection only. Goal: ${goal}` }
  ];

  return plan.map((step) => {
    const agent = agents.find((item) => item.id === step.agentId);
    return createTask(agent, step.preset, step.presetEnglish, step.detail, {
      parentTaskId,
      dispatchRole:"child"
    });
  });
}

function getActiveDispatchChildren() {
  if (!activeDispatch) return [];
  return activeDispatch.childTaskIds
    .map((taskId) => tasks.find((task) => task.id === taskId || task.bridgeTaskId === taskId))
    .filter(Boolean);
}

function isTerminalStatus(status) {
  return status === "completed" || status === "failed";
}

async function advanceActiveDispatch() {
  if (!activeDispatch || activeDispatch.status !== "running") return;
  const children = getActiveDispatchChildren();
  const activeChild = children.find((task) => task.status === "running");
  if (activeChild) return;

  const waitingForBridge = children.find((task) => task.bridgeTaskId && task.status === "queued");
  if (waitingForBridge) return;

  const nextChild = children.find((task) => !task.bridgeTaskId && task.status === "queued");
  if (nextChild) {
    const originalId = nextChild.id;
    const originalPrompt = nextChild.generatedPrompt;
    const originalPayload = nextChild.commandPayload;
    const bridgeTask = await sendTaskToBridge(nextChild);
    Object.assign(nextChild, bridgeTask, {
      id:bridgeTask.id,
      bridgeTaskId:bridgeTask.id,
      parentTaskId:activeDispatch.parentTaskId,
      dispatchRole:"child",
      generatedPrompt:originalPrompt,
      commandPayload:originalPayload
    });
    activeDispatch.childTaskIds = activeDispatch.childTaskIds.map((taskId) => taskId === originalId ? nextChild.id : taskId);
    activeDispatch.activeChildId = nextChild.id;
    latestTaskSummary.textContent = `${nextChild.agentName} · ${nextChild.taskTitle} · ${statusThai[nextChild.status]}`;
    renderCommandPanel();
    return;
  }

  if (children.length > 0 && children.every((task) => isTerminalStatus(task.status))) {
    finishActiveDispatch();
  }
}

function finishActiveDispatch() {
  const parentTask = tasks.find((task) => task.id === activeDispatch.parentTaskId);
  if (parentTask) {
    parentTask.status = "completed";
    parentTask.completedAt = new Date().toISOString();
    parentTask.resultSummary = "สรุปรวมเสร็จแล้ว";
    parentTask.taskTitle = "สรุปรวมเสร็จแล้ว";
  }
  activeDispatch.status = "completed";
  activeDispatch.finalNoteShown = true;
  latestTaskSummary.textContent = "งานกระจายครบทุกเอเจนต์แล้ว ตรวจ log ของแต่ละงานได้ใน Codex Bridge";
  taskWarning.textContent = "สรุปรวมเสร็จแล้ว";
  taskWarning.classList.remove("warning");
  renderCommandPanel();
}

function getTaskAgent(task) {
  return agents.find((agent) => agent.id === task.agentId);
}

