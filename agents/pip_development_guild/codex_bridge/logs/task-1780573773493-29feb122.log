    font-size:12px;
    font-weight:900;
  }
  .launcher-state.warning {
    color:#ffd2b8;
  }
  .bridge-state {
    min-height:18px;
    margin-top:8px;
    color:var(--gold-soft);
    font-size:12px;
    font-weight:900;
  }
  .bridge-state.offline {
    color:#ffd2b8;
  }
  .prompt-box:placeholder-shown {
    color:#f0dcc4;
    font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
  }
  .generate-button:disabled,
  .choice-button:disabled {
    cursor:not-allowed;
    opacity:.48;
    filter:saturate(.7);
  }
  .generate-button:disabled:hover,
  .choice-button:disabled:hover {
    border-color:rgba(240, 198, 107, .62);
    filter:saturate(.7);
  }
  .copy-icon:disabled {
    cursor:not-allowed;
    opacity:.45;
  }
  .copy-icon:disabled:hover {
    border-color:rgba(255, 226, 165, .34);
    background:rgba(0,0,0,.18);
  }
  .bridge-state {
    margin-top:8px;
    color:#f0dcc4;
    font-size:12px;
    font-weight:900;
  }
  .bridge-state.offline {
    color:#ffd2b8;
  }
  .bridge-state.ready {
    color:#b8efb1;
  }
  .command-panel {
    position:fixed;
    top:14px;
    right:14px;
    z-index:110;
    width:min(360px, calc(100vw - 28px));
    max-height:calc(100vh - 28px);
    border:1px solid rgba(239, 198, 106, .54);
    border-radius:16px;
    background:rgba(18, 24, 32, .84);
    box-shadow:0 18px 42px rgba(0,0,0,.38), inset 0 0 0 1px rgba(255,255,255,.06);
    backdrop-filter:blur(8px);
    overflow:hidden;
    transition:transform .18s ease;
    pointer-events:none;
  }
  .command-panel.collapsed {
    transform:translateX(100%);
  }
  .command-panel > * {
    pointer-events:auto;
  }
  .command-head {
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:10px;
    padding:12px 12px 9px;
    border-bottom:1px solid rgba(239, 198, 106, .22);
  }
  .command-title {
    margin:0;
    color:#fff8e8;
    font-size:15px;
    line-height:1.2;
    font-weight:1000;
  }
  .command-mode {
    margin:4px 0 0;
    color:var(--gold-soft);
    font-size:11px;
    line-height:1.35;
    font-weight:900;
  }
  .panel-toggle {
    width:32px;
    height:32px;
    flex:0 0 auto;
    border:1px solid rgba(255, 226, 165, .36);
    border-radius:9px;
  }
  .command-panel-tab {
    position:fixed;
    top:14px;
    right:0;
    z-index:111;
    display:none;
    align-items:center;
    gap:7px;
    min-height:42px;
    padding:8px 12px 8px 11px;
    border:1px solid rgba(239, 198, 106, .54);
    border-right:0;
    border-radius:12px 0 0 12px;
    background:rgba(18, 24, 32, .92);
    color:#fff8e8;
    box-shadow:0 18px 42px rgba(0,0,0,.30), inset 0 0 0 1px rgba(255,255,255,.04);
    backdrop-filter:blur(8px);
    cursor:pointer;
    pointer-events:auto;
    font-size:12px;
    font-weight:1000;
  }
  .command-panel-tab .icon {
    width:18px;
    height:18px;
  }
  .command-panel-tab:hover,
  .command-panel-tab:focus-visible {
    outline:none;
    border-color:rgba(255, 226, 165, .90);
    background:rgba(255,255,255,.10);
  }
  .command-panel.is-collapsed + .command-panel-tab {
    display:inline-flex;
  }
  .command-body {
    display:grid;
    gap:10px;
    max-height:calc(100vh - 94px);
    padding:11px 12px 14px;
    overflow:auto;
  }
  .command-section {
    border:1px solid rgba(255, 226, 165, .16);
    border-radius:12px;
    padding:10px;
    background:rgba(247, 234, 212, .06);
  }
  .command-section h2 {
    margin:0 0 7px;
    color:#fff4cf;
    font-size:12px;
    line-height:1.25;
  }
  .command-empty,
  .command-item {
    margin:0;
    color:#f0dcc4;
    font-size:12px;
    line-height:1.42;
  }
  .command-item + .command-item {
