  }
  .status-idle { background:#d7c6aa; }
  .status-queued { background:#ffe2a1; }
  .status-running { background:#9fd2ff; }
  .status-completed { background:#aee3a3; }
  .status-failed { background:#ffb19b; }
  @keyframes idleBreath {
    0%, 100% { transform:scale(1); }
    50% { transform:scale(var(--scale)); }
  }
  @keyframes idleSteady {
    0%, 100% { transform:scale(1); }
    50% { transform:scale(var(--scale)); }
  }
  @keyframes idleLively {
    0%, 100% { transform:translateX(0) scale(1); }
    25% { transform:translateX(-1px) scale(1.004); }
    50% { transform:translateX(0) scale(var(--scale)); }
    75% { transform:translateX(1px) scale(1.004); }
  }
